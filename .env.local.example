# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
#
# ─── Agora ──────────────────────────────────────────────────────────────────
# Found in: Agora Console → Project → App ID
# Safe to expose client-side (EXPO_PUBLIC_ prefix required for Expo apps).
EXPO_PUBLIC_AGORA_APP_ID=your_agora_app_id_here

# Server-side only — read by netlify/functions/agora-token.ts
# Also set these in: Netlify Dashboard → Site → Environment Variables
AGORA_APP_ID=your_agora_app_id_here

# Found in: Agora Console → Project → Primary Certificate
# SECRET — never prefix with EXPO_PUBLIC_, never commit.
AGORA_APP_CERTIFICATE=your_agora_app_certificate_here

# ─── OpenAI ─────────────────────────────────────────────────────────────────
EXPO_PUBLIC_OPENAI_API_KEY=your_openai_key_here

# ─── Google Cast / Chromecast ────────────────────────────────────────────────
# Cast Receiver App ID.
#
# For Agora live-call casting (custom receiver required):
#   1. Deploy cast-receiver/index.html (run: bash cast-receiver/deploy.sh)
#   2. Register at https://cast.google.com/publish → Add Application →
#      Custom Receiver → enter the hosted URL → copy the issued App ID
#   3. Register your Chromecast serial number as a test device (while unpublished)
#   4. Paste the App ID below and rebuild with EAS (eas build --profile development)
EXPO_PUBLIC_CAST_APP_ID=CC1AD845

# URL where cast-receiver/index.html is hosted.
# Must be HTTPS. Only needed if EXPO_PUBLIC_CAST_APP_ID is a custom receiver ID.
EXPO_PUBLIC_CAST_RECEIVER_URL=https://your-project.web.app/cast-receiver/
