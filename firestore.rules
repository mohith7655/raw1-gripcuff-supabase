rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }
    function validateString(field, maxLen) {
      return !request.resource.data.keys().hasAll([field])
             || (request.resource.data[field] is string && request.resource.data[field].size() <= maxLen);
    }

    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isOwner(userId) && !request.resource.data.keys().hasAny(['isAdmin','role']);
      allow update: if isOwner(userId) && !request.resource.data.keys().hasAny(['isAdmin','role']);
      allow delete: if isOwner(userId);

      match /{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    match /scheduledWorkouts/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /reminders/{docId} {
      allow get:    if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list:   if isSignedIn();  // WHERE clause in query enforces userId filter
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /chatRooms/{chatRoomId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid
                      && validateString('text', 2000);
        allow update: if isSignedIn() && resource.data.senderId == request.auth.uid
                      && validateString('text', 2000);
        allow delete: if isSignedIn() && (resource.data.senderId == request.auth.uid || isAdmin());
      }
    }

    match /workoutSessions/{sessionId} {
      allow read:   if isSignedIn() && (resource == null
                    || resource.data.hostUid == request.auth.uid
                    || resource.data.guestUid == request.auth.uid
                    || resource.data.isPublic == true);
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.hostUid == request.auth.uid
                    || resource.data.guestUid == request.auth.uid || isAdmin());
    }

    match /friendRequests/{docId} {
      allow read:   if isSignedIn() && (resource.data.fromUid == request.auth.uid
                    || resource.data.toUid == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.fromUid == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.fromUid == request.auth.uid
                    || resource.data.toUid == request.auth.uid);
      allow delete: if isSignedIn() && (resource.data.fromUid == request.auth.uid
                    || resource.data.toUid == request.auth.uid);
    }

    match /friends/{docId} {
      allow read, write: if isSignedIn();
    }

    match /notifications/{notifId} {
      allow read:   if isSignedIn() && resource.data.toUid == request.auth.uid;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (resource.data.toUid == request.auth.uid || isAdmin());
    }

    match /videoComments/{videoId}/comments/{commentId} {
      allow read:   if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /liveViewers/{videoId}/viewers/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid
                            && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (request.auth.uid == uid
                    || (resource.data.lastActive != null &&
                        resource.data.lastActive < request.time - duration.value(120, 's')));
    }

    match /strangerInvites/{inviteId} {
      allow read:   if isSignedIn() && (resource.data.inviterId == request.auth.uid
                    || resource.data.targetUserId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.inviterId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.inviterId == request.auth.uid
                    || resource.data.targetUserId == request.auth.uid);
      allow delete: if false;
    }

    match /leaderboards/{boardId} {
      allow read: if true;
      allow write: if isAdmin();

      match /{document=**} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    match /rewards/{rewardId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /activity/{activityId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /weeklyChallenges/{challengeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Catch-all for any new collections during development
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
