# OpenAI API
EXPO_PUBLIC_OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Google Places API (used for location picker on Profile screen)
# Get from Google Cloud Console → APIs & Services → Credentials
# For production: add to Netlify environment variables (never commit the real key)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=

# Note: Copy this to .env.local after adding your actual credentials
